<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <MSDeployServiceURL>https://win8119.site4now.net:8172/msdeploy.axd</MSDeployServiceURL>
    <DeployIisAppPath>seonyx-001-site1</DeployIisAppPath>
    <UserName>seonyx-001</UserName>
    <SkipExtraFilesOnServer>True</SkipExtraFilesOnServer>
    <AllowUntrustedCertificate>True</AllowUntrustedCertificate>
    <EnableMSDeployBackup>False</EnableMSDeployBackup>
  </PropertyGroup>
  <ItemGroup>
    <MsDeploySkipRules Include="SkipWebConfig">
      <ObjectName>filePath</ObjectName>
      <AbsolutePath>Web\.config</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipBookEditorFiles">
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>App_Data\\BookEditorFiles</AbsolutePath>
    </MsDeploySkipRules>
  </ItemGroup>
</Project>
