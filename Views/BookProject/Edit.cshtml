@model Seonyx.Web.Models.ViewModels.BookEditor.BookProjectViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Edit Project - " + Model.ProjectName;
}

@section Styles {
    <link href="~/Content/css/book-editor.css" rel="stylesheet" />
}

<div class="page-header">
    <h1>Edit Project: @Model.ProjectName</h1>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Back to Projects</a>
</div>

@using (Html.BeginForm("Edit", "BookProject", FormMethod.Post, new { @class = "admin-form" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.BookProjectID)

    <div class="form-group">
        @Html.LabelFor(m => m.ProjectName)
        @Html.TextBoxFor(m => m.ProjectName, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.ProjectName, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Author)
        @Html.TextBoxFor(m => m.Author, new { @class = "form-control", placeholder = "e.g. Steve Avis" })
        @Html.ValidationMessageFor(m => m.Author, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label>
            @Html.CheckBoxFor(m => m.IsActive) Active
        </label>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
    </div>
}

<hr />

<h2>Cover Image</h2>
@if (!string.IsNullOrEmpty(Model.CoverImagePath))
{
    <div class="current-cover" style="margin-bottom: 1rem;">
        <p>Current cover image is set.</p>
    </div>
}

@using (Html.BeginForm("UploadCover", "BookProject", new { id = Model.BookProjectID }, FormMethod.Post, new { enctype = "multipart/form-data", @class = "admin-form" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label for="coverImage">Upload Cover Image (JPG, PNG, or GIF)</label>
        <input type="file" name="coverImage" id="coverImage" accept=".jpg,.jpeg,.png,.gif" class="form-control" />
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-secondary">Upload Cover</button>
    </div>
}

<hr />

<div class="project-info">
    <p><strong>Created:</strong> @Model.CreatedDate.ToString("MMM d, yyyy h:mm tt")</p>
    <p><strong>Last Modified:</strong> @Model.LastModifiedDate.ToString("MMM d, yyyy h:mm tt")</p>
    <p><strong>Folder:</strong> @Model.FolderPath</p>
</div>
