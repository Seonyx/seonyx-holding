@model Seonyx.Web.Models.ViewModels.BookEditor.DraftDiffViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Draft Compare - " + Model.ProjectName;
    var current = Model.Chapters.FirstOrDefault(c => c.ChapterNumber == Model.CurrentChapterNumber);
}

@section Styles {
    <link href="~/Content/css/book-editor.css" rel="stylesheet" />
}

<div class="page-header">
    <h1>Draft Compare: @Model.ProjectName</h1>
    <a href="@Url.Action("Index", "BookProject")" class="btn btn-secondary">Back to Projects</a>
</div>

<div class="diff-controls">
    @using (Html.BeginForm("Diff", "Draft", FormMethod.Get, new { @class = "diff-picker-form" }))
    {
        <input type="hidden" name="projectId" value="@Model.BookProjectID" />
        <label>Compare</label>
        <select name="draftA" class="form-control-inline">
            @foreach (var d in Model.AvailableDrafts)
            {
                <option value="@d" @(d == Model.DraftA ? "selected" : "")>Draft @d</option>
            }
        </select>
        <label>vs</label>
        <select name="draftB" class="form-control-inline">
            @foreach (var d in Model.AvailableDrafts)
            {
                <option value="@d" @(d == Model.DraftB ? "selected" : "")>Draft @d</option>
            }
        </select>
        <button type="submit" class="btn btn-secondary">Compare</button>
    }
</div>

<div class="diff-summary">
    <span class="diff-label">@Model.LabelA</span>
    <span class="diff-arrow">&rarr;</span>
    <span class="diff-label">@Model.LabelB</span>
    <span class="diff-stats">
        @if (Model.TotalAdded > 0)    { <span class="badge-added">+@Model.TotalAdded added</span> }
        @if (Model.TotalRemoved > 0)  { <span class="badge-removed">-@Model.TotalRemoved removed</span> }
        @if (Model.TotalModified > 0) { <span class="badge-modified">~@Model.TotalModified modified</span> }
        @if (Model.TotalUnchanged > 0){ <span class="badge-unchanged">@Model.TotalUnchanged unchanged</span> }
        <span class="diff-chapter-count">across @Model.Chapters.Count chapter(s)</span>
    </span>
</div>

@if (!Model.Chapters.Any())
{
    <div class="empty-state">
        <p>No paragraph version data found for these drafts. Import both drafts first.</p>
    </div>
}
else
{
    @* Chapter navigation bar *@
    <div class="diff-chapter-nav">
        @if (Model.PrevChapterNumber.HasValue)
        {
            <a href="@Url.Action("Diff", "Draft", new { projectId = Model.BookProjectID, draftA = Model.DraftA, draftB = Model.DraftB, chapter = Model.PrevChapterNumber.Value })"
               class="btn btn-secondary diff-nav-btn">&larr; Prev</a>
        }
        else
        {
            <span class="btn btn-secondary diff-nav-btn disabled">&larr; Prev</span>
        }

        <select class="form-control-inline diff-chapter-jump"
                onchange="window.location=this.value">
            @foreach (var ch in Model.Chapters)
            {
                var url = Url.Action("Diff", "Draft", new { projectId = Model.BookProjectID, draftA = Model.DraftA, draftB = Model.DraftB, chapter = ch.ChapterNumber });
                var label = "Ch " + ch.ChapterNumber + (string.IsNullOrEmpty(ch.ChapterTitle) ? "" : ": " + ch.ChapterTitle);
                if (ch.HasChanges)
                {
                    label += " (" + (ch.AddedCount > 0 ? "+" + ch.AddedCount : "") + (ch.RemovedCount > 0 ? " -" + ch.RemovedCount : "") + (ch.ModifiedCount > 0 ? " ~" + ch.ModifiedCount : "") + ")";
                }
                else
                {
                    label += " - no changes";
                }
                <option value="@url" @(ch.ChapterNumber == Model.CurrentChapterNumber ? "selected" : "")>@label</option>
            }
        </select>

        @if (Model.NextChapterNumber.HasValue)
        {
            <a href="@Url.Action("Diff", "Draft", new { projectId = Model.BookProjectID, draftA = Model.DraftA, draftB = Model.DraftB, chapter = Model.NextChapterNumber.Value })"
               class="btn btn-secondary diff-nav-btn">Next &rarr;</a>
        }
        else
        {
            <span class="btn btn-secondary diff-nav-btn disabled">Next &rarr;</span>
        }
    </div>

    @* Current chapter diff *@
    if (current == null)
    {
        <div class="empty-state"><p>Chapter not found.</p></div>
    }
    else
    {
        <div class="diff-chapter">
            <div class="diff-chapter-header">
                <h2>Chapter @current.ChapterNumber@(string.IsNullOrEmpty(current.ChapterTitle) ? "" : ": " + current.ChapterTitle)</h2>
                <span class="diff-chapter-stats">
                    @if (current.AddedCount > 0)   { <span class="badge-added">@current.AddedCount added</span> }
                    @if (current.RemovedCount > 0)  { <span class="badge-removed">@current.RemovedCount removed</span> }
                    @if (current.ModifiedCount > 0) { <span class="badge-modified">@current.ModifiedCount modified</span> }
                    @if (!current.HasChanges)       { <span class="badge-unchanged">no changes</span> }
                </span>
            </div>

            @if (!current.HasChanges)
            {
                <p class="diff-no-changes">No changes in this chapter.</p>
            }
            else
            {
                <div class="diff-rows">
                    @foreach (var row in current.Rows)
                    {
                        if (row.Status == "unchanged") { continue; }

                        <div class="diff-row diff-@row.Status">
                            <div class="diff-pid">
                                @row.Pid
                                @if (row.CurrentParagraphID.HasValue)
                                {
                                    <a href="@Url.Action("Index", "Editor", new { projectId = Model.BookProjectID, paragraphId = row.CurrentParagraphID.Value })"
                                       class="diff-edit-link" title="Open in editor">&#8599; view</a>
                                }
                            </div>
                            @if (row.Status == "added")
                            {
                                <div class="diff-cell diff-cell-empty">(not in draft @Model.DraftA)</div>
                                <div class="diff-cell diff-cell-added">@row.TextB</div>
                            }
                            else if (row.Status == "removed")
                            {
                                <div class="diff-cell diff-cell-removed">@row.TextA</div>
                                <div class="diff-cell diff-cell-empty">(removed in draft @Model.DraftB)</div>
                            }
                            else if (row.Status == "modified")
                            {
                                <div class="diff-cell diff-cell-old">@row.TextA</div>
                                <div class="diff-cell diff-cell-new">@row.TextB</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* Bottom navigation (mirrors top) *@
        <div class="diff-chapter-nav diff-chapter-nav-bottom">
            @if (Model.PrevChapterNumber.HasValue)
            {
                <a href="@Url.Action("Diff", "Draft", new { projectId = Model.BookProjectID, draftA = Model.DraftA, draftB = Model.DraftB, chapter = Model.PrevChapterNumber.Value })"
                   class="btn btn-secondary diff-nav-btn">&larr; Prev</a>
            }
            else
            {
                <span class="btn btn-secondary diff-nav-btn disabled">&larr; Prev</span>
            }
            <span class="diff-nav-label">Chapter @current.ChapterNumber of @Model.Chapters.Count</span>
            @if (Model.NextChapterNumber.HasValue)
            {
                <a href="@Url.Action("Diff", "Draft", new { projectId = Model.BookProjectID, draftA = Model.DraftA, draftB = Model.DraftB, chapter = Model.NextChapterNumber.Value })"
                   class="btn btn-secondary diff-nav-btn">Next &rarr;</a>
            }
            else
            {
                <span class="btn btn-secondary diff-nav-btn disabled">Next &rarr;</span>
            }
        </div>
    }
}
