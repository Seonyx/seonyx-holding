# Normalise all text files to LF in the repository.
# Vimes (Linux) and GitHub Actions runners get LF; Dibbler (Windows) gets CRLF on checkout.
* text=auto eol=lf

# Source files — always LF
*.cs        text eol=lf diff=csharp
*.cshtml    text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.xml       text eol=lf
*.xsd       text eol=lf
*.json      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.config    text eol=lf
*.txt       text eol=lf
*.pubxml    text eol=lf
*.html      text eol=lf

# PowerShell — CRLF on checkout so scripts run correctly on Windows
*.ps1       text eol=crlf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.eot   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
*.zip   binary
*.dll   binary
*.exe   binary
*.pdb   binary
